# Kopieer dit bestand naar .env en vul je eigen waarden in.
# .env staat in .gitignore en hoort NOOIT in GitHub.
# De pipeline draait ook zonder .env (volledig op de sync-JSON).

# --- Routing (optioneel) ---
# Lopend boekjaar: alleen documenten uit dit jaar komen in aanmerking voor AUTO.
CM_FISCAL_YEAR=2024
# Confidence-drempel (0..1) waarboven een document AUTO mag.
CM_AUTO_THRESHOLD=0.80

# --- Live Moneybird-sync (optioneel; alleen nodig voor een live sync) ---
MONEYBIRD_ADMINISTRATION_ID=
MONEYBIRD_API_TOKEN=
MONEYBIRD_API_BASE_URL=https://moneybird.com/api/v2
